# Site URL — canonical domain used for SEO metadata, sitemaps, and robots.txt
# Defaults to https://costsmart.co if not set
NEXT_PUBLIC_SITE_URL=

# PayPal client ID for the Pro tier checkout on /pricing
# Get yours at https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# PayPal credentials for server-side subscription verification
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPal API base URL (sandbox or production)
# Sandbox: https://api-m.sandbox.paypal.com
# Production: https://api-m.paypal.com
PAYPAL_BASE_URL=

# PayPal Webhook ID for signature verification
PAYPAL_WEBHOOK_ID=

# Vercel KV (Redis) connection details
# Provision a KV store at https://vercel.com/dashboard/stores
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
# Botpress customer assistant configuration script URL
# Example: https://files.bpcontent.cloud/<path-to-your-bot-config>.js
NEXT_PUBLIC_BOTPRESS_BOT_URL=

# Google Solar API key for solar potential insights
# Get yours at https://console.cloud.google.com/apis/credentials
GOOGLE_SOLAR_API_KEY=

# Google Maps API key for Routes, Geocoding, and Places APIs
# Get yours at https://console.cloud.google.com/apis/credentials
# Enable these APIs: Routes API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY=

# Azure AI Services endpoint and key
# Powers the Document Scanner (Receipt OCR), Translator, Financial Health Analyzer, and Voice features
# Get yours at https://portal.azure.com under Cognitive Services
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=

# Zapier Catch Hook URL for lead capture automation
# Create a Zap with "Webhooks by Zapier" trigger (Catch Hook) and paste the URL here
ZAPIER_WEBHOOK_URL=

# Enable/disable lead capture Zapier webhook integration
# Forms still work locally without Zapier when set to false or unset
NEXT_PUBLIC_LEAD_CAPTURE_ENABLED=true
