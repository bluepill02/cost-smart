# PayPal client ID for the Pro tier checkout on /pricing
# Get yours at https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# PayPal credentials for server-side subscription verification
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPal API base URL (sandbox or production)
# Sandbox: https://api-m.sandbox.paypal.com
# Production: https://api-m.paypal.com
PAYPAL_BASE_URL=

# PayPal Webhook ID for signature verification
PAYPAL_WEBHOOK_ID=

# Vercel KV (Redis) connection details
# Provision a KV store at https://vercel.com/dashboard/stores
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
# Botpress customer assistant configuration script URL
# Example: https://files.bpcontent.cloud/<path-to-your-bot-config>.js
NEXT_PUBLIC_BOTPRESS_BOT_URL=

# Google Solar API key for solar potential insights
# Get yours at https://console.cloud.google.com/apis/credentials
GOOGLE_SOLAR_API_KEY=
