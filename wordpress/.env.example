# Copy this file to .env before running Docker Compose.
WORDPRESS_PORT=8080
WORDPRESS_URL=http://localhost:8080
WORDPRESS_TITLE=CostSmart

# Change these before exposing the site outside your machine.
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=change-me-now
WORDPRESS_ADMIN_EMAIL=admin@example.com

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_ROOT_PASSWORD=wordpress-root
